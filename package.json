{
  "name": "agent-manager",
  "version": "1.2.0",
  "description": "Claude Agent Manager — Monitor and manage Claude CLI agents",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build:web": "vite build -c vite.web.config.ts",
    "build": "npm run build:web && electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-rebuild -f -w node-pty",
    "rebuild-pty": "electron-rebuild -f -w node-pty",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "electron-store": "^10.0.0",
    "node-pty": "^1.0.0",
    "uuid": "^11.1.0",
    "express": "^4.21.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/express": "^5.0.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.14",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "^34.0.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "zustand": "^5.0.0"
  }
}
